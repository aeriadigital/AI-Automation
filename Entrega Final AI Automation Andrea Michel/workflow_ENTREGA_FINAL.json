    {
      "parameters": {
        "jsCode": "const data = $input.item.json;\n\n// Gemini: content.parts[0].text\n// OpenAI: message.content\n// AI Agent: output\nlet rawContent =\n  data?.content?.parts?.[0]?.text ??\n  data?.output ??\n  data?.message?.content ??\n  data?.content ??\n  '';\n\nrawContent = String(rawContent ?? '').trim();\n\nlet summary = 'No se pudo generar el resumen.';\nlet reasons = ['No se pudieron identificar las razones.'];\nlet suggested_reply = 'Lamentamos tu experiencia. Nos comunicaremos a la brevedad.';\n\ntry {\n  const cleaned = rawContent.replace(/```json/gi, '').replace(/```/g, '').trim();\n  const parsed = JSON.parse(cleaned);\n  summary = parsed.summary ?? summary;\n  reasons = Array.isArray(parsed.reasons) ? parsed.reasons : reasons;\n  suggested_reply = parsed.suggested_reply ?? suggested_reply;\n} catch (e) {\n  summary = rawContent.substring(0, 300);\n}\n\nconst tweetText = $('⚙️ Parsear Respuesta LLM').item.json.tweet_text ?? '';\nconst usuario   = $('⚙️ Parsear Respuesta LLM').item.json.usuario ?? 'desconocido';\nconst fecha     = $('⚙️ Parsear Respuesta LLM').item.json.fecha ?? '';\nconst score     = $('⚙️ Parsear Respuesta LLM').item.json.score ?? 0;\n\nreturn {\n  json: {\n    tweet_text: tweetText,\n    usuario,\n    fecha,\n    score,\n    summary,\n    reasons,\n    suggested_reply,\n    reasons_formatted: reasons.map((r, i) => `${i + 1}. ${r}`).join('\\n')\n  }\n};"
      },
