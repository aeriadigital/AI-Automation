      "id": "4ff64680-5944-4f22-9f3e-665d3f940362",
      "name": "📋 Preparar Datos del Tweet",
      "type": "n8n-nodes-base.set",
      "position": [
        -688,
        672
      ],
      "typeVersion": 3.4
    },
    {
      "parameters": {
        "jsCode": "// Extraer texto según el modelo que uses (Gemini o OpenAI)\nconst data = $input.item.json;\n\n// Gemini: content.parts[0].text\n// OpenAI: message.content\n// Fallback: content directo como string\nlet rawContent =\n  data?.content?.parts?.[0]?.text ??   // Gemini\n  data?.message?.content ??             // OpenAI\n  data?.content ??                       // genérico\n  '';\n\n// Garantizar que sea string pase lo que pase\nrawContent = String(rawContent ?? '').trim();\n\nlet sentiment = 'NEUTRAL';\nlet score = 0.5;\nlet parseError = false;\n\ntry {\n  const cleaned = rawContent.replace(/```json/gi, '').replace(/```/g, '').trim();\n  const parsed = JSON.parse(cleaned);\n\n  const validValues = ['POSITIVO', 'NEGATIVO', 'NEUTRAL'];\n  if (parsed.sentiment && validValues.includes(parsed.sentiment.toUpperCase())) {\n    sentiment = parsed.sentiment.toUpperCase();\n    score = typeof parsed.score === 'number' ? parsed.score : 0.5;\n  } else {\n    const upper = rawContent.toUpperCase();\n    if (upper.includes('NEGATIVO')) sentiment = 'NEGATIVO';\n    else if (upper.includes('POSITIVO')) sentiment = 'POSITIVO';\n    else sentiment = 'NEUTRAL';\n    parseError = true;\n  }\n} catch (e) {\n  // Fallback por keywords si el JSON falla\n  const upper = rawContent.toUpperCase();\n  if (upper.includes('NEGATIVO')) sentiment = 'NEGATIVO';\n  else if (upper.includes('POSITIVO')) sentiment = 'POSITIVO';\n  else sentiment = 'NEUTRAL';\n  parseError = true;\n}\n\n// Recuperar datos del tweet del nodo anterior\nconst tweetText = $('📋 Preparar Datos del Tweet').item.json.tweet_text ?? '';\nconst usuario   = $('📋 Preparar Datos del Tweet').item.json.usuario ?? 'desconocido';\nconst fecha     = $('📋 Preparar Datos del Tweet').item.json.fecha ?? new Date().toISOString();\n\nreturn {\n  json: {\n    sentiment,\n    score,\n    tweet_text: tweetText,\n    usuario,\n    fecha,\n    raw_llm_response: rawContent,\n    parse_error: parseError\n  }\n};"
      },
      "id": "6e28d208-19cb-4b5f-bf83-9a7e24aa6256",
      "name": "⚙️ Parsear Respuesta LLM",
