      "parameters": {
        "jsCode": "const dateFormatter = new Intl.DateTimeFormat(\"es-AR\", {\n  timeZone: \"America/Argentina/Buenos_Aires\",\n  day: \"2-digit\",\n  month: \"2-digit\",\n  year: \"numeric\",\n});\n\nconst timeFormatter = new Intl.DateTimeFormat(\"es-AR\", {\n  timeZone: \"America/Argentina/Buenos_Aires\",\n  hour: \"2-digit\",\n  minute: \"2-digit\",\n  hour12: false,\n});\n\n// formatter SOLO para obtener la hora numérica\nconst hourFormatter = new Intl.DateTimeFormat(\"en-US\", {\n  timeZone: \"America/Argentina/Buenos_Aires\",\n  hour: \"2-digit\",\n  hour12: false,\n});\n\nfor (const item of $input.all()) {\n  const raw = item.json.current_date_and_time;\n  const d = new Date(raw);\n\n  const hourAR = Number(hourFormatter.format(d));\n\n  item.json.formatted_date = dateFormatter.format(d);\n  item.json.formatted_time = timeFormatter.format(d);\n\n  // 👉 variable que querés\n  item.json.afternoon_message_on = hourAR >= 18;\n}\n\nreturn $input.all();"
      },
